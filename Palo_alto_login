.firewall = ""

if exists(.dvchost) {
    .firewall = string!(.dvchost)
}

.device = .firewall

if exists(.deviceExternalId) {
    .serial = string!(.deviceExternalId)
}

if exists(.cs3) {
    .vsys = string!(.cs3)
}




if exists(.msg) {

    msg = string!(.msg)

    if contains(msg,"logged in") {

        .event_category = "administrator"
        .event_action = "login"

    }

    if contains(msg,"logged out") {

        .event_category = "administrator"
        .event_action = "logout"

    }

}







SELECT
_timestamp,
firewall,
event_category,
event_action,
msg
FROM "paloalto"
ORDER BY _timestamp DESC
LIMIT 100
