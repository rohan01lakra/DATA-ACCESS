    .threat_type = "malware"
}

# Severity
if contains(msg,"critical") {
    .severity = "critical"
}

if contains(msg,"high") {
    .severity = "high"
}

if contains(msg,"medium") {
    .severity = "medium"
}

if contains(msg,"low") {
    .severity = "low"
}

# Action
