# ==========================================

msg = ""

if exists(.msg) {
    msg = string!(.msg)
} else {
    msg = string!(.message)
}

# Threat Category
if contains(msg, "Threat") ||
   contains(msg, "Virus") ||
   contains(msg, "Spyware") ||
   contains(msg, "Vulnerability") ||
   contains(msg, "WildFire") {

    .event_category = "threat"
}

# Antivirus
if contains(msg, "Virus") {
    .threat_type = "virus"
}

# Spyware
if contains(msg, "Spyware") {
    .threat_type = "spyware"
}

# Vulnerability
if contains(msg, "Vulnerability") {
    .threat_type = "vulnerability"
}

# WildFire
