🐍 3. backup.py (Universal Script)
import paramiko
import datetime
import os
import yaml
from concurrent.futures import ThreadPoolExecutor

USERNAME = os.getenv("ROUTER_USER")
PASSWORD = os.getenv("ROUTER_PASS")

# Load inventory
with open("inventory.yml") as f:
    inventory = yaml.safe_load(f)

devices = inventory["devices"]

def backup_device(device):
    ip = device["ip"]
    name = device.get("name", ip)
    command = device["command"]

    try:
        ssh = paramiko.SSHClient()
        ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())

        ssh.connect(ip, username=USERNAME, password=PASSWORD, timeout=10)

        stdin, stdout, stderr = ssh.exec_command(command)
        output = stdout.read().decode()

        ssh.close()

        timestamp = datetime.datetime.now().strftime("%Y-%m-%d_%H-%M-%S")
        folder = f"NETWORK-BACKUP/{name}"
        filename = f"{folder}/{ip}_{timestamp}.txt"

        os.makedirs(folder, exist_ok=True)

        with open(filename, "w") as f:
            f.write(output)

        print(f"[SUCCESS] {name} ({ip}) backup saved")

    except Exception as e:
        print(f"[ERROR] {name} ({ip}): {str(e)}")

# Parallel execution
with ThreadPoolExecutor(max_workers=5) as executor:
    executor.map(backup_device, devices)
⚙️ 4. .gitlab-ci.yml (Same for all devices)
stages:
  - backup

backup_all_devices:
  stage: backup
  image: python:3.11

  only:
    - schedules

  before_script:
    - apt-get update && apt-get install -y openssh-client git
    - pip install paramiko pyyaml

    # SSH known hosts
    - mkdir -p ~/.ssh
    - for ip in 10.250.250.35 10.250.250.36 10.250.250.50 10.250.250.60; do ssh-keyscan $ip >> ~/.ssh/known_hosts; done

    # Git config
    - git config --global user.email "backup@gitlab.com"
    - git config --global user.name "GitLab Backup Bot"

  script:
    - python backup.py
    - git add NETWORK-BACKUP/
    - git diff --cached --quiet || git commit -m "Daily network backup $(date)"
    - git push https://oauth2:${CI_JOB_TOKEN}@${CI_SERVER_HOST}/${CI_PROJECT_PATH}.git HEAD:main
